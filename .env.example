# Clinical Curator Environment Variables
# Copy this to .env and fill in your values.
#
# The same `.env` at the repo root is consumed by:
#   - docker-compose (server / db / redis secrets below)
#   - the Flutter clinical app   (via flutter_dotenv, loaded in main.dart)
#   - the Flutter admin app      (via flutter_dotenv, loaded in main.dart)
# Both Flutter apps read the SAME file so they never drift onto different
# backends — admin approvals always reach the clinical app's Serverpod.

# ─── Database (Docker) ──────────────────────────────────────────────────────
DB_PASSWORD=your_database_password_here
DB_TEST_PASSWORD=your_test_database_password_here

# ─── Redis (Docker) ─────────────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password_here
REDIS_TEST_PASSWORD=your_test_redis_password_here

# ─── Serverpod ──────────────────────────────────────────────────────────────
SERVICE_SECRET=your_service_secret_here

# ─── Flutter apps (clinical + admin) ────────────────────────────────────────
# ENV ∈ {mock, dev, staging, prod}. Overrides --dart-define=ENV when present.
ENV=dev

# Serverpod backend URL used by BOTH apps. MUST be identical so admin
# verifications propagate to the clinical app.
SERVERPOD_URL=http://localhost:8080/
SERVERPOD_HOST=localhost
SERVERPOD_PORT=8080

# OAuth / third-party (leave blank to disable the feature at runtime).
GOOGLE_CLIENT_ID=
KHALTI_PUBLIC_KEY=
ESEWA_PUBLIC_KEY=
