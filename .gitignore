# ─── Workspace-wide (matches at any depth) ──────────────────────────────────
# `build/` and `.dart_tool/` without a leading slash so they apply to
# every package + app in the monorepo, not just the root.

# Build outputs
build/
**/build/

# Dart / Pub
.dart_tool/
**/.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
pubspec.lock.bak

# Generated Flutter platform files (when bootstrapped fresh per app)
**/.flutter-plugins
**/ios/.symlinks/
**/ios/Pods/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/macos/Flutter/GeneratedPluginRegistrant.swift
**/macos/Flutter/ephemeral/
**/android/.gradle/
**/android/captures/
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
**/android/app/debug
**/android/app/profile
**/android/app/release
**/windows/flutter/ephemeral/
**/linux/flutter/ephemeral/

# Coverage
coverage/
**/coverage/

# ─── IDE / editor ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
out/
gen/
.atom/
.buildlog/
.history

# ─── Misc ───────────────────────────────────────────────────────────────────
*.class
*.log
*.pyc
*.swp

# ─── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db

# ─── Serverpod ──────────────────────────────────────────────────────────────
clinical_curator_server/config/passwords.yaml
clinical_curator_server/web/app/

# ─── Docker ─────────────────────────────────────────────────────────────────
docker-compose.override.yaml

# ─── Environment / secrets ──────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Melos ──────────────────────────────────────────────────────────────────
.melos_tool/
pubspec_overrides.yaml
**/pubspec_overrides.yaml

# Library lockfiles — applications keep theirs (apps/*, clinical_curator_server),
# but workspace packages are libraries and shouldn't pin transitive deps.
packages/*/pubspec.lock

# ─── Project artifacts that get regenerated ─────────────────────────────────
# Hive registrar is generated by build_runner — keep it tracked since
# isar_service.dart depends on it. Don't ignore *.g.dart globally.
